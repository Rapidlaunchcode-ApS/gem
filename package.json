{
  "name": "gem",
  "version": "0.2.3",
  "description": "Gem — the context-aware clipboard for macOS. Every copy, kept and understood.",
  "main": "./out/main/index.js",
  "type": "module",
  "private": true,
  "author": "Rapidlaunchcode",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "dompurify": "^3.2.4",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "build": {
    "appId": "app.rapidlaunchcode.gem",
    "productName": "Gem",
    "afterPack": "build/afterPack.cjs",
    "afterSign": "build/notarize.cjs",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dir",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon-1024.png",
      "signAndEditExecutable": false,
      "artifactName": "Gem-Windows-Setup.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
