diff --git a/dist/cjs/index.js b/dist/cjs/index.js
index a8e99778a052f17bfeacf8f02d50ddd099cc2968..d095d469930c570c42ca8666bc0032bfc0751482 100644
--- a/dist/cjs/index.js
+++ b/dist/cjs/index.js
@@ -111,6 +111,14 @@ const makeUniversalApp = async (opts) => {
                     // The mismatch here is OK so we just move on to the next one
                     continue;
                 }
+                // Code-signature seals (the app's own Contents/_CodeSignature/CodeResources
+                // and every nested framework's) legitimately differ per-arch because each
+                // upstream arch ships only its own v8_context_snapshot.<arch>.bin. The final
+                // universal app is fully re-signed after the merge, which regenerates these
+                // seals correctly, so a pre-merge mismatch here is safe to ignore.
+                if (file.relativePath.includes('_CodeSignature/')) {
+                    continue;
+                }
                 throw new Error(`Expected all non-binary files to have identical SHAs when creating a universal build but "${file.relativePath}" did not`);
             }
         }
